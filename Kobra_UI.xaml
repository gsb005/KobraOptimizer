<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraOptimizer v1.5.3"
        Height="760"
        Width="1240"
        MinHeight="700"
        MaxHeight="840"
        MinWidth="1180"
        MaxWidth="1460"
        Background="#0B0B0B"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00FF41"/>
        <SolidColorBrush x:Key="AccentBrushDark" Color="#00CC35"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#141414"/>
        <SolidColorBrush x:Key="SubPanelBrush" Color="#191919"/>
        <SolidColorBrush x:Key="SubPanelBrushAlt" Color="#111111"/>
        <SolidColorBrush x:Key="ChromeBrush" Color="#252525"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#CFCFCF"/>
        <SolidColorBrush x:Key="FooterBrush" Color="#8D8D8D"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#00AA2B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#101010"/>
            <Setter Property="Foreground" Value="#F6F6F6"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#F6F6F6"/>
            <Setter Property="Background" Value="#101010"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#101010"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#8D8D8D" Text="▶" Visibility="Collapsed" x:Name="SubmenuArrow"/>
                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,4,0,0"
                                            Background="#141414"
                                            BorderBrush="#2B2B2B"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="4">
                                        <ScrollViewer CanContentScroll="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#1B1B1B"/>
                                <Setter TargetName="MenuItemBorder" Property="BorderBrush" Value="#00AA2B"/>
                                <Setter TargetName="MenuItemBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="18" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KobraBaseButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#232323"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00FF41" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2F2F2F"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#00AA2B"/>
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="26" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1F1F1F"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#00FF41"/>
                                <Setter TargetName="ButtonBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF41" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KobraAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource KobraBaseButtonStyle}">
            <Setter Property="Background" Value="#00FF41"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#00FF41"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2BFF63"/>
                    <Setter Property="BorderBrush" Value="#2BFF63"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#00CC35"/>
                    <Setter Property="BorderBrush" Value="#00CC35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KobraToolButtonStyle" TargetType="Button" BasedOn="{StaticResource KobraBaseButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,12,14"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border Margin="0,10,0,0"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FF41" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
                                </Border.Effect>
                            </Border>
                            <Border Margin="12,0,0,0"
                                    Padding="8,0"
                                    Background="#0B0B0B"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <ContentPresenter Margin="12,28,12,12"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="KobraComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#2F2F2F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="18,6,0,0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <Border x:Name="ComboBorder"
                                        CornerRadius="8"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="34"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Margin="10,0,6,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          IsHitTestVisible="False"/>
                                        <Border Grid.Column="1"
                                                CornerRadius="0,8,8,0"
                                                Background="#1E1E1E"
                                                BorderBrush="#2F2F2F"
                                                BorderThickness="1,0,0,0">
                                            <TextBlock Text="▼"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#CFCFCF"
                                                       FontSize="11"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="280"
                                        CornerRadius="8"
                                        Background="#141414"
                                        BorderBrush="#2B2B2B"
                                        BorderThickness="1">
                                    <ScrollViewer Margin="0">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#00AA2B"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#00FF41"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KobraComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1F1F1F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#00FF41"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Padding" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#00CC35"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F1F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#101010"/>
            <Setter Property="Foreground" Value="#00FF41"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#131313" BorderBrush="#262626" BorderThickness="0,0,1,0">
            <StackPanel Margin="18,18,18,18">
                <TextBlock Text="KOBRA" Foreground="#00FF41" FontSize="34" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="OPTIMIZER" FontSize="13" HorizontalAlignment="Center" Margin="0,-4,0,12"/>

                <Border Width="160" Height="160" Background="#0F0F0F" CornerRadius="12" BorderBrush="#262626" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Grid>
                        <Ellipse Width="132" Height="132" Fill="#141414" Stroke="#00AA2B" StrokeThickness="1" Opacity="0.8">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00FF41" BlurRadius="24" ShadowDepth="0" Opacity="0.55"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Image Name="KobraLogo" Width="132" Height="132" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>

                <Button Name="BtnAnalyze" Content="ANALYZE" Style="{StaticResource KobraBaseButtonStyle}" Background="#232323" Foreground="White" ToolTip="Scan the current selections and estimate reclaimable space."/>
                <Button Name="BtnRunSelected" Content="EXECUTE SELECTED" Style="{StaticResource KobraAccentButtonStyle}" ToolTip="Run the selected cleanup and tuning actions after confirmation."/>
                <Button Name="BtnQuickShed" Content="QUICK SHED" Style="{StaticResource KobraBaseButtonStyle}" ToolTip="Run a fast cleanup using Kobra's safe default cleanup set."/>
                <Button Name="BtnCreateBackup" Content="CREATE BACKUP" Style="{StaticResource KobraBaseButtonStyle}" ToolTip="Create a backup bundle of important settings before deeper changes."/>
                <Button Name="BtnOpenLogs" Content="OPEN LOGS" Style="{StaticResource KobraBaseButtonStyle}" ToolTip="Open the folder where Kobra writes log files."/>
                <Button Name="BtnOpenManifests" Content="OPEN MANIFESTS" Style="{StaticResource KobraBaseButtonStyle}" ToolTip="Open the folder where delete manifests are saved."/>

                <Rectangle Height="1" Fill="#00FF41" Opacity="0.35" Margin="0,6,0,10"/>

                <Button Name="BtnExit" Content="EXIT" Style="{StaticResource KobraBaseButtonStyle}" Margin="0,0,0,0" ToolTip="Close KobraOptimizer."/>

                <Border Margin="0,16,0,0" Padding="12" Background="#101010" CornerRadius="10" BorderBrush="#262626" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="v1.5.2 hotfix" Foreground="#00FF41" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Text="• Stronger neon hover and section glow" TextWrapping="Wrap" FontSize="12" Foreground="#CFCFCF"/>
                        <TextBlock Text="• Menu bar with File / Tools / Help" TextWrapping="Wrap" FontSize="12" Foreground="#CFCFCF" Margin="0,6,0,0"/>
                        <TextBlock Text="• Toggleable log panel and laptop-friendly height" TextWrapping="Wrap" FontSize="12" Foreground="#CFCFCF" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogRow" Height="220"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Menu Grid.Row="0">
                <MenuItem Header="_File">
                    <MenuItem Header="_Analyze" Name="MenuFileAnalyze"/>
                    <MenuItem Header="_Execute Selected" Name="MenuFileExecute"/>
                    <Separator/>
                    <MenuItem Header="_Quick Shed" Name="MenuFileQuickShed"/>
                    <MenuItem Header="_Create Backup" Name="MenuFileBackup"/>
                    <Separator/>
                    <MenuItem Header="E_xit" Name="MenuFileExit"/>
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="Open _Logs" Name="MenuToolsLogs"/>
                    <MenuItem Header="Open _Manifests" Name="MenuToolsManifests"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_Donate" Name="MenuHelpSupport"/>
                    <MenuItem Header="_Disclaimer" Name="MenuHelpDisclaimer"/>
                    <Separator/>
                    <MenuItem Header="_About Me" Name="MenuHelpAbout"/>
                </MenuItem>
            </Menu>

            <TextBlock Grid.Row="1" Text="Custom Optimization Console" Foreground="#00FF41" FontSize="22" FontWeight="Bold" Margin="0,8,0,12">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FF41" BlurRadius="20" ShadowDepth="0" Opacity="0.35"/>
                </TextBlock.Effect>
            </TextBlock>

            <Border Grid.Row="2" Background="#111111" BorderBrush="#242424" BorderThickness="1" CornerRadius="12" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*"/>
                            <ColumnDefinition Width="0.95*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <GroupBox Header="System Cleanup">
                                <StackPanel>
                                    <CheckBox Name="ChkUserTemp" Content="User Temp" IsChecked="True"/>
                                    <CheckBox Name="ChkSystemTemp" Content="System Temp" IsChecked="True"/>
                                    <CheckBox Name="ChkWinUpdate" Content="Windows Update Cache"/>
                                    <CheckBox Name="ChkThumbCache" Content="Thumbnail / Icon Cache" IsChecked="True"/>
                                    <CheckBox Name="ChkShaderCache" Content="DirectX Shader Cache"/>
                                    <CheckBox Name="ChkRecycleBin" Content="Recycle Bin" IsChecked="True"/>
                                    <TextBlock Text="Shader cache will rebuild after cleanup; first game launch can be slower." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12" Margin="0,10,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Browser Cache Cleanup">
                                <StackPanel>
                                    <CheckBox Name="ChkChrome" Content="Google Chrome"/>
                                    <CheckBox Name="ChkEdge" Content="Microsoft Edge"/>
                                    <CheckBox Name="ChkFirefox" Content="Firefox"/>
                                    <TextBlock Text="Preserves saved passwords, bookmarks, and profile databases." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12" Margin="0,10,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Startup Apps Manager">
                                <StackPanel>
                                    <CheckBox Name="ChkStartupShowMicrosoft" Content="Show Microsoft entries" Margin="0,0,0,6"/>
                                    <ListView Name="StartupList" Height="210" SelectionMode="Extended">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="160"/>
                                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                                                <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Location}" Width="100"/>
                                                <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Kind}" Width="90"/>
                                                <GridViewColumn Header="Command" DisplayMemberBinding="{Binding Command}" Width="240"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <Button Name="BtnStartupRefresh" Content="Refresh" Width="84" Margin="0,0,8,0" Style="{StaticResource KobraBaseButtonStyle}"/>
                                        <Button Name="BtnStartupDisable" Content="Disable selected" Width="126" Margin="0,0,8,0" Style="{StaticResource KobraBaseButtonStyle}"/>
                                        <Button Name="BtnStartupEnable" Content="Re-enable selected" Width="138" Margin="0,0,0,0" Style="{StaticResource KobraBaseButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <GroupBox Header="System Tuning">
                                <StackPanel>
                                    <CheckBox Name="ChkRestorePoint" Content="Create Restore Point" IsChecked="True"/>
                                    <CheckBox Name="ChkRegistry" Content="TLS Hardening"/>
                                    <CheckBox Name="ChkNetwork" Content="Network TCP Strike"/>
                                    <CheckBox Name="ChkDnsFlush" Content="Flush DNS Cache"/>
                                    <CheckBox Name="ChkDnsProfile" Content="Apply DNS Profile"/>
                                    <ComboBox Name="CmbDnsProvider" Style="{StaticResource KobraComboBoxStyle}" SelectedIndex="0" IsEnabled="False" Opacity="0.72">
                                        <ComboBoxItem Style="{StaticResource KobraComboBoxItemStyle}" Content="Cloudflare (1.1.1.1 / 1.0.0.1)"/>
                                        <ComboBoxItem Style="{StaticResource KobraComboBoxItemStyle}" Content="Google (8.8.8.8 / 8.8.4.4)"/>
                                        <ComboBoxItem Style="{StaticResource KobraComboBoxItemStyle}" Content="Automatic / DHCP"/>
                                    </ComboBox>
                                    <CheckBox Name="ChkHPDebloat" Content="HP Telemetry Trim"/>
                                    <TextBlock Text="Network tweaks are the most system-wide changes here. Keep Restore Point checked before using them." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12" Margin="0,10,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Windows Tools">
                                <UniformGrid Columns="2" Margin="0,4,0,0">
                                    <Button Name="BtnWindowsUpdate" Content="Check for updates" Margin="0,0,8,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open the Windows Update action page."/>
                                    <Button Name="BtnWindowsUpdateSettings" Content="Update settings" Margin="0,0,0,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open Windows Update settings."/>
                                    <Button Name="BtnWindowsStorage" Content="Storage" Margin="0,0,8,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open Storage Sense and storage settings."/>
                                    <Button Name="BtnWindowsApps" Content="Apps &amp; Features" Margin="0,0,0,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open installed apps and features."/>
                                    <Button Name="BtnWindowsStartupSettings" Content="Startup Apps" Margin="0,0,8,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open the built-in Startup Apps settings page."/>
                                    <Button Name="BtnWindowsGameMode" Content="Game Mode" Margin="0,0,0,8" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open Game Mode settings."/>
                                    <Button Name="BtnWindowsGraphics" Content="Graphics settings" Margin="0,0,8,0" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open advanced graphics settings."/>
                                    <Button Name="BtnWindowsPower" Content="Power &amp; sleep" Margin="0,0,0,0" Style="{StaticResource KobraToolButtonStyle}" ToolTip="Open power and sleep settings."/>
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="Compatibility Notes">
                                <StackPanel>
                                    <TextBlock Text="• Startup manager shows Run keys and Startup folders, with disabled items preserved for re-enable." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12"/>
                                    <TextBlock Text="• Open the Windows Tools section for safe settings pages instead of forcing unknown tweaks." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12" Margin="0,8,0,0"/>
                                    <TextBlock Text="• Use Analyze before Execute so the user can see estimated impact and review the manifest." TextWrapping="Wrap" Foreground="#CFCFCF" FontSize="12" Margin="0,8,0,0"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="3" Margin="0,12,0,10" Background="#101010" BorderBrush="#1E1E1E" BorderThickness="1" CornerRadius="10" Padding="12,6">
                <DockPanel>
                    <TextBlock Text="Status Log" Foreground="#00FF41" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                    <Button Name="BtnToggleLog"
                            Content="Hide log"
                            Style="{StaticResource KobraToolButtonStyle}"
                            Width="90"
                            Margin="0,0,0,0"
                            DockPanel.Dock="Right"
                            ToolTip="Show or hide the log panel."/>
                    <TextBlock Text="Workspace above scrolls independently" Foreground="#8D8D8D" FontSize="11" HorizontalAlignment="Right" Margin="8,0,0,0"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="4" Background="#151515" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="12" Padding="10">
                <TextBox Name="StatusTextBox"
                         Background="#151515"
                         Foreground="#D8D8D8"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="13"/>
            </Border>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <ProgressBar Name="ProgBar" Height="14" Minimum="0" Maximum="100" Background="#232323" Foreground="#00FF41"/>
                <DockPanel Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Name="BtnDonate" Content="Donate" Style="{StaticResource KobraToolButtonStyle}" Width="160" Margin="0,0,8,0" ToolTip="Open the KobraOptimizer donation page."/>
                        <Button Name="BtnDisclaimer" Content="Disclaimer" Style="{StaticResource KobraToolButtonStyle}" Width="110" Margin="0,0,8,0" ToolTip="Show the disclaimer for KobraOptimizer."/>
                        <Button Name="BtnAboutMe" Content="About Me" Style="{StaticResource KobraToolButtonStyle}" Width="120" ToolTip="Learn about KobraOptimizer and its creator."/>
                    </StackPanel>
                    <TextBlock Text="KobraOptimizer v1.5.3  |  Modular PowerShell + WPF" Foreground="#8D8D8D" FontSize="11" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
