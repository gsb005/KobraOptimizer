<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraOptimizer v1.8.3"
        Height="900"
        Width="1540"
        MinHeight="780"
        MaxHeight="980"
        MinWidth="1340"
        MaxWidth="1740"
        Background="#33445D"
        FontFamily="Segoe UI Variable Text"
        FontSize="14"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AppShellBrush" Color="#33445D"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#33445D"/>
        <SolidColorBrush x:Key="SidebarCardBrush" Color="#3B4B67"/>
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#445673"/>
        <SolidColorBrush x:Key="CanvasBrush" Color="#EEF2F7"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardAltBrush" Color="#F7F9FC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D8E0EB"/>
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#E7ECF3"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#16E06E"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDF8E7"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#0E8B46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5F6B7A"/>
        <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="WhiteMutedTextBrush" Color="#D8E0EE"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PageSubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
            <Setter Property="Background" Value="#3B4B67"/>
            <Setter Property="BorderBrush" Value="#3B4B67"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource SidebarHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style x:Key="SidebarAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#102414"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0B1624"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F6F8FB"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#C9D5E4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#D7E0EC"/>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border Margin="0,11,0,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"/>
                            <Border Background="{StaticResource CanvasBrush}" Padding="8,0" Margin="14,0,0,0" HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <ContentPresenter Margin="16,30,16,16"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,2,0,2"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}" Margin="2">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F7FAFD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#F7FAFD"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="#2C394F" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="KOBRA" Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="OPTIMIZER" Foreground="{StaticResource WhiteMutedTextBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,-3,0,12"/>
                    <Border Width="122" Height="122" CornerRadius="18" Background="#2D3C55" BorderBrush="#4A5B78" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Grid>
                            <Ellipse Width="96" Height="96" Fill="#31425E" Stroke="#16E06E" StrokeThickness="1.2"/>
                            <Image Name="KobraLogo" Width="96" Height="96" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,2,0,12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Name="BtnNavDashboard" Content="Dashboard" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavAnalyze" Content="Quick Scan" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavCustomClean" Content="Custom Clean" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavResults" Content="Results" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavTools" Content="Performance" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavStartup" Content="Startup Manager" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavUtilities" Content="Tools" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavAbout" Content="About" Style="{StaticResource SidebarNavButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Border Background="#3B4B67" BorderBrush="#4A5B78" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v1.8.2 refinement" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                            <TextBlock Text="Sidebar cleanup, stronger spacing, cleaner Custom Clean cards, and calmer controls." Foreground="{StaticResource WhiteMutedTextBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Name="BtnDonateSidebar" Content="Donate" Style="{StaticResource SidebarAccentButtonStyle}"/>
                    <Button Name="BtnExit" Content="Exit" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogRow" Height="0"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource CanvasBrush}" CornerRadius="20" BorderBrush="#E0E7F0" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid Name="ViewDashboard" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="310"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Kobra Control Center" Style="{StaticResource PageTitleStyle}"/>
                                            <TextBlock Text="A cleaner, guided place to scan clutter, review results, optimize performance, and manage startup apps." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                            <WrapPanel>
                                                <Button Name="BtnDashboardQuickScan" Content="Quick Scan" Width="148" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnQuickShed" Content="Quick Shed" Width="148" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDashboardCustomClean" Content="Custom Clean" Width="148" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDashboardPerformance" Content="Performance" Width="148" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDashboardStartup" Content="Startup Manager" Width="168" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                        <StackPanel>
                                            <TextBlock Text="Safety first" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtDashSafety" Text="No backup bundle yet. Create one before deep system changes." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,0,0,18">
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="LAST SCAN" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashLastScan" Text="No scan yet" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="RECLAIMABLE" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashReclaimable" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="RECORDS FOUND" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashRecords" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="CATEGORIES" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashCategories" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                </UniformGrid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.35*"/>
                                        <ColumnDefinition Width="0.65*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Recent activity" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBox Name="TxtRecentActivity" Margin="0,12,0,0" MinHeight="210" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#F7FAFD" BorderBrush="{StaticResource BorderSoftBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="Selected profile" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Name="TxtDashSelections" Text="No cleanup categories selected yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="What is new" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="- Cleaner sidebar shell&#x0a;- Softer typography and calmer buttons&#x0a;- Separate pages for scan, clean, performance, startup, tools, and about" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewAnalyze" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Quick Scan" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Run the recommended scan path, then move into a cleaner review screen with totals and selected actions." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Name="TxtAnalyzeStage" Text="Quick Scan is ready" FontSize="28" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtAnalyzeSubStage" Text="Run the recommended scan here, or open Custom Clean to fine-tune what Kobra reviews." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <WrapPanel Margin="0,0,0,6">
                                                <Button Name="BtnAnalyze" Content="Run Quick Scan" Width="170" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnQuickScanCustomize" Content="Open Custom Clean" Width="170" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnQuickScanBackup" Content="Create Backup" Width="150" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                        <StackPanel>
                                            <TextBlock Text="Recommended scan profile" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="- User Temp&#x0a;- System Temp&#x0a;- Windows Update Cache&#x0a;- Thumbnail / Icon Cache&#x0a;- Recycle Bin&#x0a;- Chrome and Edge browser cache" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="3" Margin="0,4,0,0">
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="#F7FAFD"><StackPanel><TextBlock Text="System junk" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Temp files, update cache, icon cache, and recycle bin in one pass." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="#F7FAFD"><StackPanel><TextBlock Text="Browser cleanup" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Chrome, Edge, and Firefox cache options with optional cookie cleanup." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD"><StackPanel><TextBlock Text="Safe flow" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Analyze first, review the results, then confirm before running cleanup." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/></StackPanel></Border>
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewCustomClean" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Custom Clean" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Tune exactly what Kobra scans, keep browser options separate, and optionally include safe registry trace cleanup with a backup-first flow." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.98*"/>
                                        <ColumnDefinition Width="1.02*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="System cleanup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Choose the Windows and local cleanup categories you want Kobra to scan." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <StackPanel>
                                                    <CheckBox Name="ChkUserTemp" Content="User Temp"/>
                                                    <CheckBox Name="ChkSystemTemp" Content="System Temp"/>
                                                    <CheckBox Name="ChkWinUpdate" Content="Windows Update Cache"/>
                                                    <CheckBox Name="ChkThumbCache" Content="Thumbnail / Icon Cache"/>
                                                    <CheckBox Name="ChkShaderCache" Content="DirectX Shader Cache"/>
                                                    <CheckBox Name="ChkRecycleBin" Content="Recycle Bin"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Browser cleanup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Keep browser choices explicit so cookie cleanup and browser caches stay easy to understand." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <StackPanel>
                                                    <CheckBox Name="ChkChrome" Content="Google Chrome"/>
                                                    <CheckBox Name="ChkEdge" Content="Microsoft Edge"/>
                                                    <CheckBox Name="ChkFirefox" Content="Firefox"/>
                                                    <CheckBox Name="ChkBrowserCookies" Content="Include cookies (may sign you out)"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Scan setup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Select categories on the left, then analyze to generate a cleaner review screen and manifest." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,16"/>
                                                <WrapPanel Margin="0,0,0,6">
                                                    <Button Name="BtnCustomAnalyze" Content="Analyze Selected" Width="170" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Content="Review Results" Width="150" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource CardAltBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Registry cleanup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Optional safe user-trace cleanup. Kobra can back up the related registry keys before removing them." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <CheckBox Name="ChkRegistryCleanup" Content="Clean registry traces (Run history, Typed URLs, search history, recent docs)"/>
                                                <CheckBox Name="ChkRegistryBackup" Content="Create registry backup before cleanup" IsChecked="True"/>
                                            </StackPanel>
                                        </Border>
                                        <UniformGrid Columns="2" Margin="0,0,0,0">
                                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="{StaticResource CardAltBrush}">
                                                <StackPanel>
                                                    <TextBlock Text="Why Custom Clean" FontSize="17" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Keep the simple Quick Scan path separate from deeper category tuning." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource CardAltBrush}">
                                                <StackPanel>
                                                    <TextBlock Text="Good defaults" FontSize="17" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Cookies stay optional, shader cache stays separate, and browser choices remain explicit." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewResults" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Review Results" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Review the items Kobra found, confirm the selected categories, then clean when you are ready." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*"/>
                                        <ColumnDefinition Width="0.85*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Name="TxtResultsHeadline" Text="No removable records detected" FontSize="30" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtResultsSubHeadline" Text="Analyze has not been run yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <ListView Name="ResultsList" MinHeight="360">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="280"/>
                                                        <GridViewColumn Header="Items" DisplayMemberBinding="{Binding ItemsText}" Width="110"/>
                                                        <GridViewColumn Header="Size" DisplayMemberBinding="{Binding SizeText}" Width="110"/>
                                                        <GridViewColumn Header="Notes" DisplayMemberBinding="{Binding Note}" Width="300"/>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="Selected for cleanup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Name="TxtSelectedCategoryCount" Text="0 categories selected" Margin="0,12,0,0"/>
                                                <TextBlock Name="TxtSelectedRecordCount" Text="0 records selected" Margin="0,6,0,0"/>
                                                <TextBlock Name="TxtSelectedBytes" Text="0 MB selected" Margin="0,6,0,0"/>
                                                <TextBlock Name="TxtSelectedWarnings" Text="Review the results, then run Clean Selected when you are ready." Style="{StaticResource PageSubTitleStyle}" Margin="0,14,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Create backups from the Tools page before deeper changes." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnRunSelected" Content="Clean Selected" Width="150" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewTools" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Performance" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Keep cleanup separate from performance actions so optimization stays clearer, safer, and easier to understand." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <GroupBox Header="Performance actions">
                                            <StackPanel>
                                                <CheckBox Name="ChkRestorePoint" Content="Create restore point before deeper system changes"/>
                                                <CheckBox Name="ChkRegistry" Content="TLS and registry hardening"/>
                                                <CheckBox Name="ChkNetwork" Content="Network TCP strike"/>
                                                <CheckBox Name="ChkDnsFlush" Content="Flush DNS cache"/>
                                                <CheckBox Name="ChkDnsProfile" Content="Apply DNS profile"/>
                                                <ComboBox Name="CmbDnsProvider" Width="210" Margin="22,8,0,0">
                                                    <ComboBoxItem Content="Cloudflare (1.1.1.1 / 1.0.0.1)"/>
                                                    <ComboBoxItem Content="Google (8.8.8.8 / 8.8.4.4)"/>
                                                    <ComboBoxItem Content="Automatic / DHCP"/>
                                                </ComboBox>
                                                <CheckBox Name="ChkHPDebloat" Content="HP telemetry trim"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <WrapPanel>
                                            <Button Name="BtnPerformanceApply" Content="Apply Selected" Width="160" Style="{StaticResource PrimaryButtonStyle}"/>
                                            <Button Name="BtnPerformanceBackup" Content="Create Backup" Width="150" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <GroupBox Header="Windows shortcuts">
                                            <UniformGrid Columns="2">
                                                <Button Name="BtnWindowsUpdate" Content="Check for updates" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsUpdateSettings" Content="Update settings" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsStorage" Content="Storage" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsApps" Content="Apps and Features" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsStartupSettings" Content="Startup Apps" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsGameMode" Content="Game Mode" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsGraphics" Content="Graphics settings" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsPower" Content="Power and sleep" Style="{StaticResource ToolButtonStyle}"/>
                                            </UniformGrid>
                                        </GroupBox>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="Why this page matters" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Network changes, DNS profiles, and OEM trimming stay separate from cleanup so the app feels cleaner and easier to trust." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewStartup" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Startup Manager" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Review startup entries in their own page so boot clutter is easier to control without mixing it with cleanup tasks." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <GroupBox Header="Startup entries">
                                    <StackPanel>
                                        <CheckBox Name="ChkStartupShowMicrosoft" Content="Show Microsoft startup items too"/>
                                        <ListView Name="StartupList" Margin="0,12,0,0" MinHeight="420">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="190"/>
                                                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="90"/>
                                                    <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Location}" Width="130"/>
                                                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Kind}" Width="90"/>
                                                    <GridViewColumn Header="Command" DisplayMemberBinding="{Binding Command}" Width="430"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                        <WrapPanel Margin="0,12,0,0">
                                            <Button Name="BtnStartupRefresh" Content="Refresh" Width="100" Style="{StaticResource SecondaryButtonStyle}"/>
                                            <Button Name="BtnStartupDisable" Content="Disable selected" Width="150" Style="{StaticResource SecondaryButtonStyle}"/>
                                            <Button Name="BtnStartupEnable" Content="Re-enable selected" Width="160" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,0"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewUtilities" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Tools" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Backup, manifest, and support utilities stay in one place so the main cleanup flow stays focused and clean." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Maintenance" FontSize="18" FontWeight="SemiBold"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnCreateBackup" Content="Create Backup" Width="150" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Name="BtnOpenLogs" Content="Open Logs" Width="130" Style="{StaticResource SecondaryButtonStyle}"/>
                                                    <Button Name="BtnOpenManifests" Content="Open Manifests" Width="150" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                                <Button Name="BtnToggleLog" Content="Show advanced log" Width="170" Style="{StaticResource GhostButtonStyle}" Margin="0,12,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                            <StackPanel>
                                                <TextBlock Text="Why it is separate" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Normal users should see the clean app first. Logs and manifests are still here, but they stay out of the way unless you need them." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewAbout" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="About Kobra" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="KobraOptimizer is evolving into a cleaner utility suite while keeping the practical PowerShell engine that already powers cleanup, backup, startup, and tuning features." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Project direction" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="- Cleaner section-based app shell&#x0a;- Bigger focus on scan, results, options, and actions&#x0a;- Less developer clutter in the main interface&#x0a;- Room to add more features after the UI feels great" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#F7FAFD">
                                        <StackPanel>
                                            <TextBlock Text="Support and info" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="Free utility. Practical tools. Cleaner direction. Ongoing development." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <WrapPanel>
                                                <Button Name="BtnDonate" Content="Donate" Width="120" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnDisclaimer" Content="Disclaimer" Width="120" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnAboutMe" Content="About Me" Width="120" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,12,0,10">
                <DockPanel>
                    <TextBlock Text="Kobra status" Foreground="{StaticResource MutedTextBrush}" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <ProgressBar Name="ProgBar" Height="14" Minimum="0" Maximum="100" Background="#E7EDF5" Foreground="{StaticResource AccentDarkBrush}" BorderThickness="0"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10">
                <TextBox Name="StatusTextBox"
                         Background="#FFFFFF"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="13"/>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,6,0,0">
                <TextBlock Text="KobraOptimizer v1.8.2  |  UI refinement pass on the current backend" Foreground="#E5EDF7" FontSize="11"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
