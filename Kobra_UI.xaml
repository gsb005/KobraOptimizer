                    </Grid>

                    <Grid Name="ViewOperationProgress" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Optimization in Progress" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,18"/>

                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="40" Background="#FFFCFD">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Name="TxtBigStatus" Text="Kobra is analyzing your system..." Style="{StaticResource OperationStatusTitleStyle}" Margin="0,0,0,26"/>
                                <Grid Width="900" MaxWidth="900" Height="64">
                                    <ProgressBar Name="BigProgBar" Minimum="0" Maximum="100" Value="0" Width="900" MaxWidth="900" Style="{StaticResource OperationProgressBarStyle}"/>
                                    <Border BorderBrush="#E7DADF" BorderThickness="1" CornerRadius="12" Background="Transparent"/>
                                    <TextBlock Text="{Binding ElementName=BigProgBar, Path=Value, StringFormat={}{0:0}%}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#4A343A" FontWeight="Bold" FontSize="18"/>
                                </Grid>
                                <TextBlock Name="TxtBigDetail" Text="Preparing modules..." Style="{StaticResource OperationDetailStyle}" Margin="0,24,0,0" MaxWidth="900"/>
                                <Button Name="BtnCancelScan" Content="Stop Operation" Width="180" Height="40" Margin="0,42,0,0" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Name="ViewCustomClean" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Custom Clean" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Tune exactly what Kobra scans, keep browser options separate, add safe registry cleanup with backup protection, and move into a more reviewable results flow." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.98*"/>
                                        <ColumnDefinition Width="1.02*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="System cleanup" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Choose the Windows and local cleanup categories you want Kobra to scan." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <StackPanel>
                                                    <CheckBox Name="ChkUserTemp" Content="User Temp" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkSystemTemp" Content="System Temp" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkWinUpdate" Content="Windows Update Cache" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkThumbCache" Content="Thumbnail / Icon Cache" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkShaderCache" Content="DirectX Shader Cache" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkRecycleBin" Content="Recycle Bin" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkSystemRestorePoint" Content="Create restore point before clean" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                </StackPanel>
                                                <WrapPanel Margin="0,16,0,0">
                                                    <Button Name="BtnSystemScan" Content="Scan System" Width="140" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Name="BtnSystemClean" Content="Clean System" Width="140" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Browser cleanup" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Scan real browser cache, cookies, and browsing history without touching bookmarks or saved passwords." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <StackPanel>
                                                    <CheckBox Name="ChkChrome" Content="Google Chrome" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkEdge" Content="Microsoft Edge" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkFirefox" Content="Firefox" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkOpera" Content="Opera / Opera GX" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkBrave" Content="Brave" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkVivaldi" Content="Vivaldi" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkBrowserCookies" Content="Include cookies (may sign you out)" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkBrowserHistory" Content="Include browsing history where safe to remove" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkBrowserBackupBundle" Content="Create safety backup before clean" Style="{StaticResource CleanCheckBoxStyle}" Visibility="Collapsed" IsChecked="False"/>
                                                    <TextBlock Text="Safety backups run separately. Use Create Safety Backup before cleaning if you want DNS, TLS, and network-related recovery files saved first." Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <WrapPanel Margin="0,16,0,0">
                                                    <Button Name="BtnBrowserScan" Content="Scan Browser" Width="150" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Name="BtnBrowserClean" Content="Clean Browser" Width="150" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                                <TextBlock Text="Bookmarks and saved passwords are preserved. Cookies and history are only removed if selected." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource CardAltBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Registry cleanup" Style="{StaticResource SectionTitleStyle}"/>
                                                <TextBlock Text="Safe registry traces only. Review grouped trace results on the Results page before cleaning." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,10"/>
                                                <StackPanel>
                                                    <CheckBox Name="ChkRegistryClean" Content="Registry traces (Run history, Typed Paths, Recent Docs)" Style="{StaticResource CleanCheckBoxStyle}"/>
                                                    <CheckBox Name="ChkRegistryBackup" Content="Create registry backup before cleanup" Style="{StaticResource CleanCheckBoxStyle}" Visibility="Collapsed" IsChecked="False"/>
                                                    <TextBlock Text="Registry Backup is a separate step. Click Backup Registry first, then run Registry Clean." Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                                                    <TextBlock Name="TxtRegistryBackupStatus" Text="Registry backup status: No backup yet" Style="{StaticResource BodyTextStyle}" Margin="0,6,0,0" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <WrapPanel Margin="0,16,0,0">
                                                    <Button Name="BtnRegistryScan" Content="Scan Registry" Width="140" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Name="BtnRegistryBackup" Content="Backup Registry" Width="150" Style="{StaticResource SecondaryButtonStyle}"/>
                                                    <Button Name="BtnRegistryClean" Content="Clean Registry" Width="140" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                                <TextBlock Text="Back up registry traces first, then clean. Missing keys are skipped automatically." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Scan setup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Select categories on the left, then analyze to generate a cleaner review screen and manifest." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,16"/>
                                                <WrapPanel Margin="0,0,0,6">
                                                    <Button Name="BtnCustomAnalyze" Content="Analyze Selected" Width="170" Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button Content="Review Results" Width="150" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <UniformGrid Columns="2" Margin="0,0,0,0">
                                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="{StaticResource CardAltBrush}">
                                                <StackPanel>
                                                    <TextBlock Text="Why Custom Clean" FontSize="17" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Keep the simple Health Check path separate from deeper category tuning and safe registry trace cleanup." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource CardAltBrush}">
                                                <StackPanel>
                                                    <TextBlock Text="Good defaults" FontSize="17" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Cookies stay optional, shader cache stays separate, browser choices remain explicit, and registry cleanup stays conservative and backup-aware." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewResults" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Review Results" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Name="TxtResultsMode" Text="Scan completed" Foreground="{StaticResource AccentBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="Review the items Kobra found, confirm the selected categories, then clean when you are ready." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*"/>
                                        <ColumnDefinition Width="0.85*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Name="TxtResultsHeadline" Text="No removable records detected" FontSize="30" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtResultsSubHeadline" Text="Analyze has not been run yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <ListView Name="ResultsList" MinHeight="360">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="280"/>
                                                        <GridViewColumn Header="Items" DisplayMemberBinding="{Binding ItemsText}" Width="110"/>
                                                        <GridViewColumn Header="Size" DisplayMemberBinding="{Binding SizeText}" Width="110"/>
                                                        <GridViewColumn Header="Notes" DisplayMemberBinding="{Binding Note}" Width="300"/>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Selected for cleanup" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Name="TxtSelectedCategoryCount" Text="0 categories selected" Margin="0,12,0,0"/>
                                                <TextBlock Name="TxtSelectedRecordCount" Text="0 records selected" Margin="0,6,0,0"/>
                                                <TextBlock Name="TxtSelectedBytes" Text="0 MB selected" Margin="0,6,0,0"/>
                                                <TextBlock Name="TxtSelectedWarnings" Text="Review the results, then run Clean Selected when you are ready." Style="{StaticResource PageSubTitleStyle}" Margin="0,14,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Create safety backups from the Support page before deeper changes." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnRunSelected" Content="Clean Selected" Width="150" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,0"/>
                                                    <Button Name="BtnResultsRescan" Content="Rescan" Width="120" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                                                    <Button Name="BtnResultsBackCustom" Content="Back to Custom Clean" Width="180" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewTools" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Performance" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Keep cleanup separate from performance actions so optimization stays clearer, safer, and easier to understand." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <GroupBox Header="Performance actions">
                                            <StackPanel>
                                                <CheckBox Name="ChkRestorePoint" Content="Create restore point before deeper system changes"/>
                                                <CheckBox Name="ChkNetwork" Content="Network TCP strike"/>
                                                <CheckBox Name="ChkDnsFlush" Content="Flush DNS cache"/>
                                                <CheckBox Name="ChkDnsProfile" Content="Apply DNS profile"/>
                                                <ComboBox Name="CmbDnsProvider" Width="210" Margin="22,8,0,0">
                                                    <ComboBoxItem Content="Cloudflare (1.1.1.1 / 1.0.0.1)"/>
                                                    <ComboBoxItem Content="Google (8.8.8.8 / 8.8.4.4)"/>
                                                    <ComboBoxItem Content="Automatic / DHCP"/>
                                                </ComboBox>
                                                <CheckBox Name="ChkHPDebloat" Content="HP telemetry trim"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <WrapPanel>
                                            <Button Name="BtnPerformanceApply" Content="Apply Selected" Width="160" Style="{StaticResource PrimaryButtonStyle}"/>
                                            <Button Name="BtnPerformanceBackup" Content="Create Safety Backup" Width="170" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                        </WrapPanel>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource CardAltBrush}" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="TLS / Security moved to its own page" FontSize="18" FontWeight="SemiBold"/>
