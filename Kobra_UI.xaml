<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KobraOptimizer v1.8.9"
        Height="900"
        Width="1540"
        MinHeight="780"
        MaxHeight="980"
        MinWidth="1340"
        MaxWidth="1740"
        Background="#4A343A"
        FontFamily="Segoe UI Variable Display"
        FontSize="14"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AppShellBrush" Color="#4A343A"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#4A343A"/>
        <SolidColorBrush x:Key="SidebarCardBrush" Color="#5A414A"/>
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#6A4E58"/>
        <SolidColorBrush x:Key="CanvasBrush" Color="#F5F1F3"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFCFD"/>
        <SolidColorBrush x:Key="CardAltBrush" Color="#FCF7F9"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E7DADF"/>
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#F0E7EA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF5A75"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFE3EA"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#C92B57"/>
        <SolidColorBrush x:Key="TextBrush" Color="#261B21"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6F5B64"/>
        <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFFCFD"/>
        <SolidColorBrush x:Key="WhiteMutedTextBrush" Color="#F3DDE5"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PageSubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>


        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="CleanCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Padding" Value="0,3,0,3"/>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF5A75" BlurRadius="12" ShadowDepth="0" Opacity="0.20"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}"/>
            <Setter Property="Background" Value="#5A414A"/>
            <Setter Property="BorderBrush" Value="#5A414A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
                                <Setter TargetName="NavBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF5A75" BlurRadius="24" ShadowDepth="0" Opacity="0.60"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style x:Key="SidebarAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#2A111A"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF5A75" BlurRadius="22" ShadowDepth="0" Opacity="0.55"/>
                </Setter.Value>
            </Setter>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2A111A"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF7088"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFF0F4"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF5A75" BlurRadius="46" ShadowDepth="0" Opacity="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF5A75" BlurRadius="10" ShadowDepth="0" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFF0F5"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF5A75" BlurRadius="34" ShadowDepth="0" Opacity="0.86"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F5F1F3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#FCF7F9"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#E6CDD5"/>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>


        <Style x:Key="OperationStatusTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OperationDetailStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="OperationProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#F0E5E9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF5A75" BlurRadius="16" ShadowDepth="0" Opacity="0.45"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border Margin="0,11,0,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"/>
                            <Border Background="{StaticResource CanvasBrush}" Padding="8,0" Margin="14,0,0,0" HorizontalAlignment="Left">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </Border>
                            <ContentPresenter Margin="16,30,16,16"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#FFFCFD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}" Margin="2">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF8FB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FFF8FB"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="#3E2730" BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Image Name="KobraLogo" Width="260" Height="260" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" Margin="0,-58,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,-14,0,12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Button Name="BtnNavDashboard" Content="Dashboard" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavAnalyze" Content="Health Check" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavCustomClean" Content="Custom Clean" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavResults" Content="Results" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavTools" Content="Performance" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavTls" Content="TLS / Security" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavStartup" Content="Startup Manager" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavUtilities" Content="Support" Style="{StaticResource SidebarNavButtonStyle}"/>
                        <Button Name="BtnNavAbout" Content="About" Style="{StaticResource SidebarNavButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Border Background="#5A414A" BorderBrush="#7A5864" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="v1.8.9 section results" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                            <TextBlock Text="Red neon shell, visible registry cleanup, backup-first registry traces, and cleaner option styling." Foreground="{StaticResource WhiteMutedTextBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Button Name="BtnDonateSidebar" Content="Donate" Style="{StaticResource SidebarAccentButtonStyle}"/>
                    <Button Name="BtnExit" Content="Exit" Style="{StaticResource SidebarNavButtonStyle}" Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="LogRow" Height="0"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource CanvasBrush}" CornerRadius="20" BorderBrush="#EBDDE2" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid Name="ViewDashboard" Visibility="Visible">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="310"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Kobra Control Center" Style="{StaticResource PageTitleStyle}"/>
                                            <TextBlock Text="A cleaner, guided place to scan clutter, review results, optimize performance, and manage startup apps." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                            <WrapPanel>
                                                <Button Name="BtnDashboardQuickScan" Content="Health Check" Width="148" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnDashboardCustomClean" Content="Custom Clean" Width="148" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDashboardPerformance" Content="Performance" Width="148" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDashboardStartup" Content="Startup Manager" Width="168" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                        <StackPanel>
                                            <TextBlock Text="Safety first" FontSize="17" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtDashSafety" Text="No safety backup yet. Create one before deeper system changes." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,0,0,18">
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="LAST SCAN" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashLastScan" Text="No scan yet" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="RECLAIMABLE" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashReclaimable" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0"><StackPanel><TextBlock Text="RECORDS FOUND" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashRecords" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                    <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="CATEGORIES" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/><TextBlock Name="TxtDashCategories" Text="--" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/></StackPanel></Border>
                                </UniformGrid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.35*"/>
                                        <ColumnDefinition Width="0.65*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Recent activity" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBox Name="TxtRecentActivity" Margin="0,12,0,0" MinHeight="210" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#FFF8FB" BorderBrush="{StaticResource BorderSoftBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Selected profile" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Name="TxtDashSelections" Text="No cleanup categories selected yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="What is new" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="- Cleaner sidebar shell&#x0a;- Softer typography and calmer buttons&#x0a;- Separate pages for scan, clean, performance, startup, tools, and about" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewAnalyze" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Health Check" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Run the recommended machine snapshot, then move into cleanup results or deeper tuning with more context." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Name="TxtAnalyzeStage" Text="Health Check is ready" FontSize="28" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtAnalyzeSubStage" Text="Run a machine health snapshot here, or open Custom Clean to fine-tune what Kobra reviews." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <WrapPanel Margin="0,0,0,6">
                                                <Button Name="BtnAnalyze" Content="Run Health Check" Width="170" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnHealthReviewResults" Content="Review Cleanup Results" Width="190" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnQuickScanCustomize" Content="Open Custom Clean" Width="170" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnQuickScanBackup" Content="Create Safety Backup" Width="170" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                        <StackPanel>
                                            <TextBlock Text="Health snapshot includes" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="- Reclaimable cleanup space&#x0a;- TLS / security posture&#x0a;- DNS providers and adapters&#x0a;- Startup load&#x0a;- Registry traces&#x0a;- Backup and safety state" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="3" Margin="0,4,0,0">
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12" Background="#FFF8FB"><StackPanel><TextBlock Text="Cleanup Potential" FontSize="17" FontWeight="SemiBold"/><TextBlock Name="TxtHealthCleanup" Text="Run Health Check to estimate reclaimable space." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
