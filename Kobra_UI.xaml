                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="170"/>
                                                    <GridViewColumn Header="Setting" DisplayMemberBinding="{Binding SettingName}" Width="220"/>
                                                    <GridViewColumn Header="Current" DisplayMemberBinding="{Binding CurrentState}" Width="170"/>
                                                    <GridViewColumn Header="Recommended" DisplayMemberBinding="{Binding RecommendedState}" Width="160"/>
                                                    <GridViewColumn Header="Action" DisplayMemberBinding="{Binding ActionText}" Width="220"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0" Background="#FFF8FB">
                                        <StackPanel>
                                            <TextBlock Text="Preview changes" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="These are the exact changes Kobra would apply for the selected profile. Review first, then apply when ready." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,12" TextWrapping="Wrap"/>
                                            <TextBox Name="TxtTlsPreview" MinHeight="200" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#FFFFFF" BorderBrush="{StaticResource BorderSoftBrush}" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Result summary" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="After apply, Kobra summarizes changed, skipped, and already compliant settings together with reboot guidance and backup location." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,12" TextWrapping="Wrap"/>
                                            <TextBox Name="TxtTlsResultSummary" MinHeight="200" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#FFF8FB" BorderBrush="{StaticResource BorderSoftBrush}" VerticalScrollBarVisibility="Auto" Text="No TLS changes applied yet."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewStartup" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Startup Manager" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Review startup entries in their own page so boot clutter is easier to control without mixing it with cleanup tasks." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <GroupBox Header="Startup entries">
                                    <StackPanel>
                                        <CheckBox Name="ChkStartupShowMicrosoft" Content="Show Microsoft startup items too"/>
                                        <ListView Name="StartupList" Margin="0,12,0,0" MinHeight="420">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="190"/>
                                                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="90"/>
                                                    <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Location}" Width="130"/>
                                                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Kind}" Width="90"/>
                                                    <GridViewColumn Header="Command" DisplayMemberBinding="{Binding Command}" Width="430"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                        <WrapPanel Margin="0,12,0,0">
                                            <Button Name="BtnStartupRefresh" Content="Refresh" Width="100" Style="{StaticResource SecondaryButtonStyle}"/>
                                            <Button Name="BtnStartupDisable" Content="Disable selected" Width="150" Style="{StaticResource SecondaryButtonStyle}"/>
                                            <Button Name="BtnStartupEnable" Content="Re-enable selected" Width="160" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,0"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewUtilities" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Support" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Safety backup and troubleshooting tools stay here so the main cleanup flow stays focused and simple." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <Border Style="{StaticResource CardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Safety Backup" FontSize="18" FontWeight="SemiBold"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnCreateBackup" Content="Create Safety Backup" Width="180" Style="{StaticResource PrimaryButtonStyle}"/>
                                                </WrapPanel>
                                                <TextBlock Text="Backs up DNS, TLS, and network-related settings before deeper system changes." Style="{StaticResource PageSubTitleStyle}" Margin="0,12,0,0"/>
                                                <TextBlock Text="Saved in the Backups folder inside Kobra." Style="{StaticResource PageSubTitleStyle}" Margin="0,6,0,0"/>
                                                <CheckBox Name="ChkDebugLogging" Content="Enable support logging" Margin="0,14,0,0"/>
                                                <TextBlock Name="TxtDebugLogHint" Text="Support logging is off. Turn it on only if you need troubleshooting help." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                <StackPanel Name="SupportToolsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                                    <TextBlock Text="Support tools" FontSize="16" FontWeight="SemiBold"/>
                                                    <TextBlock Text="These options only appear while support logging is enabled for the current session." Style="{StaticResource PageSubTitleStyle}" Margin="0,6,0,0"/>
                                                    <WrapPanel Margin="0,12,0,0">
                                                        <Button Name="BtnOpenSupportLog" Content="Open Support Log" Width="150" Style="{StaticResource SecondaryButtonStyle}"/>
                                                        <Button Name="BtnOpenLogs" Content="Open Support Folder" Width="160" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                    </WrapPanel>
                                                    <Button Name="BtnToggleLog" Content="Show support log" Width="170" Style="{StaticResource GhostButtonStyle}" Margin="0,12,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Restore" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Restore only the settings Kobra changes, using a previous safety backup." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnSupportRestoreDns" Content="Restore DNS" Width="140" Style="{StaticResource SecondaryButtonStyle}"/>
                                                    <Button Name="BtnSupportRestoreTls" Content="Restore TLS" Width="140" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                                <TextBlock Text="TLS restores the backed-up SCHANNEL and .NET TLS settings. DNS restores the last saved adapter DNS values from your latest safety backup." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Windows Recovery" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Use Windows recovery options for broader rollback outside Kobra's own setting restores." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Name="BtnSupportCreateRestorePoint" Content="Create Windows Restore Point" Width="220" Style="{StaticResource SecondaryButtonStyle}"/>
                                                    <Button Name="BtnSupportOpenSystemRestore" Content="Open System Restore" Width="180" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewAbout" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="About Kobra" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="KobraOptimizer is evolving into a cleaner utility suite while keeping the practical PowerShell engine that already powers cleanup, backup, startup, and tuning features." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <Image Name="AboutLogo" Width="260" Height="260" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,16" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Text="Project direction" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="- Cleaner section-based app shell&#x0a;- Bigger focus on scan, results, options, and actions&#x0a;- Less developer clutter in the main interface&#x0a;- Room to add more features after the UI feels great" Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                        <StackPanel>
                                            <TextBlock Text="Support and info" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="Free utility. Practical tools. Cleaner direction. Ongoing development." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,18"/>
                                            <WrapPanel>
                                                <Button Name="BtnShare" Content="Share" Width="120" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnDonate" Content="Donate" Width="120" Style="{StaticResource PrimaryButtonStyle}"/>
                                                <Button Name="BtnDisclaimer" Content="Disclaimer" Width="120" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnAboutMe" Content="About Me" Width="120" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#FFFCFD" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,12,0,10">
                <DockPanel>
                    <TextBlock Text="Kobra status" Foreground="{StaticResource MutedTextBrush}" DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <ProgressBar Name="ProgBar" Height="12" Minimum="0" Maximum="100" Background="#F0E5E9" Foreground="{StaticResource AccentDarkBrush}" BorderThickness="0"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="#FFFCFD" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10">
                <TextBox Name="StatusTextBox"
                         Background="#FFFCFD"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="13"/>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,6,0,0">
                <TextBlock Text="KobraOptimizer v1.8.9  |  Section scan/clean + dedicated progress view" Foreground="#F2E7EB" FontSize="11"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
