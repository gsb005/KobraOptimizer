                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <GroupBox Header="Windows shortcuts">
                                            <UniformGrid Columns="2">
                                                <Button Name="BtnWindowsUpdate" Content="Check for updates" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsUpdateSettings" Content="Update settings" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsStorage" Content="Storage" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsApps" Content="Apps and Features" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsStartupSettings" Content="Startup Apps" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsGameMode" Content="Game Mode" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsGraphics" Content="Graphics settings" Style="{StaticResource ToolButtonStyle}"/>
                                                <Button Name="BtnWindowsPower" Content="Power and sleep" Style="{StaticResource ToolButtonStyle}"/>
                                            </UniformGrid>
                                        </GroupBox>
                                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                            <StackPanel>
                                                <TextBlock Text="Why this page matters" FontSize="18" FontWeight="SemiBold"/>
                                                <TextBlock Text="Network changes, DNS profiles, and OEM trimming stay separate from cleanup so the app feels cleaner and easier to trust." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Name="ViewTls" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="TLS / Security" Style="{StaticResource PageTitleStyle}"/>
                                <TextBlock Text="Scan current Windows TLS settings safely, compare them to a selected profile, preview exact registry-backed changes, back up the targeted branches, then apply only when you choose to." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,18"/>

                                <UniformGrid Columns="4" Margin="0,0,0,18">
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="STATUS" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtTlsStatusBadge" Text="Needs review" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="LEGACY" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtTlsLegacyState" Text="Run Scan TLS to inspect legacy protocol posture safely." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="MODERN" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtTlsModernState" Text="Modern protocol state will appear here after scanning." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource StatCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text=".NET" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtTlsDotNetState" Text=".NET strong crypto state will appear here after scanning." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.95*"/>
                                        <ColumnDefinition Width="1.05*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,16,0">
                                        <StackPanel>
                                            <TextBlock Text="Profile selection" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="Choose a profile, then scan or preview. Only the Recommended / Modern profile writes changes in this build." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,12"/>
                                            <TextBlock Text="Preset" FontWeight="SemiBold"/>
                                            <ComboBox Name="CmbTlsPreset" Width="320" Margin="0,8,0,0">
                                                <ComboBoxItem Content="Recommended / Modern baseline"/>
                                                <ComboBoxItem Content="Compatible review-only profile"/>
                                                <ComboBoxItem Content="Strict / Hardened preview"/>
                                            </ComboBox>
                                            <TextBlock Name="TxtTlsProfileDescription" Text="Recommended modern baseline. Disable SSL 2.0, SSL 3.0, TLS 1.0, and TLS 1.1. Preserve or re-enable TLS 1.2 and TLS 1.3. Enable .NET strong crypto and system-default TLS flags." Style="{StaticResource PageSubTitleStyle}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                                            <WrapPanel Margin="0,14,0,0">
                                                <Button Name="BtnTlsScan" Content="Scan TLS" Width="120" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnTlsRecommend" Content="Use Recommended" Width="155" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnTlsPreview" Content="Preview Changes" Width="150" Style="{StaticResource SecondaryButtonStyle}"/>
                                            </WrapPanel>
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Name="BtnTlsBackup" Content="Backup TLS Settings" Width="170" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnTlsBackupLocation" Content="Backup Location" Width="145" Style="{StaticResource SecondaryButtonStyle}"/>
                                                <Button Name="BtnTlsApply" Content="Apply TLS Baseline" Width="170" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False"/>
                                                <Button Name="BtnTlsRestore" Content="Restore TLS Backup" Width="165" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"/>
                                            </WrapPanel>
                                            <CheckBox Name="ChkTlsRestorePoint" Content="Create restore point before apply" Margin="0,14,0,0"/>
                                            <TextBlock Name="TxtTlsBackupStatus" Text="No TLS backup created yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFF8FB">
                                        <StackPanel>
                                            <TextBlock Text="Current status" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Name="TxtTlsSummary" Text="TLS scan has not been run yet." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Name="TxtTlsRecommendation" Text="Recommended modern baseline. Disable SSL 2.0, SSL 3.0, TLS 1.0, and TLS 1.1. Preserve or re-enable TLS 1.2 and TLS 1.3. Enable .NET strong crypto and system-default TLS flags." Style="{StaticResource PageSubTitleStyle}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                            <TextBox Name="TxtTlsProtocols" Margin="0,12,0,0" MinHeight="170" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#FFFFFF" BorderBrush="{StaticResource BorderSoftBrush}" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Text="Detailed matrix" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="Current state, selected profile, and action preview for each supported TLS target. Missing values are treated as Default / Not configured, and unsupported items are skipped safely." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,12" TextWrapping="Wrap"/>
