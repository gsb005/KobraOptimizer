                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12" Background="#FFF8FB"><StackPanel><TextBlock Text="DNS Status" FontSize="17" FontWeight="SemiBold"/><TextBlock Name="TxtHealthDns" Text="Run Health Check to review current DNS providers." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="#FFF8FB"><StackPanel><TextBlock Text="Startup Load" FontSize="17" FontWeight="SemiBold"/><TextBlock Name="TxtHealthStartup" Text="Current startup load will appear here." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0" Background="#FFF8FB"><StackPanel><TextBlock Text="Registry Traces" FontSize="17" FontWeight="SemiBold"/><TextBlock Name="TxtHealthRegistry" Text="Safe trace categories will appear here." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#FFF8FB"><StackPanel><TextBlock Text="Safety State" FontSize="17" FontWeight="SemiBold"/><TextBlock Name="TxtHealthSafety" Text="Backup and recovery readiness will appear here." Style="{StaticResource PageSubTitleStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/></StackPanel></Border>
